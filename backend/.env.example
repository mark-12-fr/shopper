# Copy to backend/.env and fill in.

# Session cookie signing key — set to a long random string in production.
SECRET_KEY=change-me-to-a-long-random-string

# Database. Leave unset to use a local SQLite file (backend/shopper.db).
# For your Supabase Postgres, use the CONNECTION POOLER string from
# Supabase dashboard > Project Settings > Database > Connection string (URI).
# It looks like:
# DATABASE_URL=postgresql://postgres.hjmtrfldepxcacdnzzpe:YOUR_DB_PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=
